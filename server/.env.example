# Neon (Connection string з консолі Neon)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=

# Telegram (один бот на всіх)
TELEGRAM_BOT_TOKEN=
# Без @ — для посилань запрошень у API
TELEGRAM_BOT_USERNAME=YourBotName

# Продакшен на Render: webhook + публічна URL сервісу
TELEGRAM_USE_WEBHOOK=true
PUBLIC_URL=https://your-service.onrender.com
# Опційно: окрема база для Mini App (якщо відрізняється від PUBLIC_URL)
# TELEGRAM_WEBAPP_BASE_URL=https://your-service.onrender.com
PORT=3000

# У @BotFather: Bot Settings → Menu Button / Domain — додайте той самий HTTPS-домен,
# щоб кнопки Web App відкривали Mini App усередині Telegram.

# Локальна розробка: long polling, без PUBLIC_URL
# TELEGRAM_USE_WEBHOOK=false
