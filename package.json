{
  "name": "teacherjournal",
  "version": "2.4.2",
  "description": "TeacherJournal desktop Electron app (installer-based)",
  "author": "Denis Balaka <balaka185@gmail.com>",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "docx": "^8.1.3",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.teacher.journal",
    "productName": "TeacherJournal",
    "files": [
      "electron/**",
      "assets/**",
      "board_app/**",
      "settings_app/**",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json",
      "app_config.json",
      "navigation.js",
      "utils.js",
      "module_home.js",
      "module_lessons.js",
      "module_students.js",
      "module_reports.js",
      "module_tests.js",
      "module_notes.js",
      "module_export.js",
      "module_schedule.js",
      "module_class_journal.js",
      "module_curriculum.js"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "TeacherJournal-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TeacherJournal",
      "include": "assets/nsis-uninstall-warning.nsh"
    }
  }
}
